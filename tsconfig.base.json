{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@nextrep/shared/*": ["packages/shared/src/*"],
      "@nextrep/domain/*": ["packages/domain/src/*"],
      "@nextrep/ui/*": ["packages/ui/src/*"],
      "@nextrep/auth/*": ["packages/auth/src/*"],
      "@nextrep/i18n/*": ["packages/i18n/src/*"],
      "@nextrep/assets/*": ["packages/assets/src/*"],
      "@nextrep/api-client/*": ["packages/api-client/src/*"]
    }
  }
}
